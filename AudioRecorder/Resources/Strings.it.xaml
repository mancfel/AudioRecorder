<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="WindowTitle">Registratore Audio</system:String>
    <system:String x:Key="MainTitle">Registratore Audio - Microfono + Sistema</system:String>
    <system:String x:Key="MicLabel">Microfono:</system:String>
    <system:String x:Key="SysLabel">Sistema (Loopback):</system:String>
    <system:String x:Key="WhisperModelLabel">Modello:</system:String>
    <system:String x:Key="StartButton">Avvia Registrazione</system:String>
    <system:String x:Key="StopButton">Ferma Registrazione</system:String>
    <system:String x:Key="SaveButton">Salva Registrazione</system:String>
    <system:String x:Key="StatusHeaderText">Stato:</system:String>
    <system:String x:Key="ReadyStatus">Pronto per registrare</system:String>
    <system:String x:Key="MicLevelLabel">Livello Mic:</system:String>
    <system:String x:Key="SysLevelLabel">Livello Sistema:</system:String>
    <system:String x:Key="MicTranscriptionLabel">Trascrizione (Microfono):</system:String>
    <system:String x:Key="SysTranscriptionLabel">Trascrizione (Sistema):</system:String>
    <system:String x:Key="InstructionsHeader">Istruzioni:</system:String>
    <system:String x:Key="Instruction1">• Seleziona i dispositivi di input dal menu a tendina</system:String>
    <system:String x:Key="Instruction2">• Clicca 'Avvia' per iniziare a registrare microfono e audio di sistema</system:String>
    <system:String x:Key="Instruction3">• Clicca 'Ferma' per terminare la registrazione</system:String>
    <system:String x:Key="Instruction4">• Clicca 'Salva' per salvare il file MP3 mixato</system:String>
    
    <!-- Code-behind and Status strings -->
    <system:String x:Key="SelectMicWarning">Seleziona un microfono prima di iniziare la registrazione.</system:String>
    <system:String x:Key="DeviceNotSelectedTitle">Dispositivo non selezionato</system:String>
    <system:String x:Key="Mp3Filter">File Mp3|*.mp3</system:String>
    <system:String x:Key="RecordingFilenamePrefix">Registrazione_</system:String>
    <system:String x:Key="SaveError">Errore nel salvataggio: </system:String>
    <system:String x:Key="ErrorTitle">Errore</system:String>
    <system:String x:Key="NoWhisperModelsFound">Nessun modello Whisper (.bin) trovato in AppData/AudioRecorder</system:String>
    <system:String x:Key="ModelLoadError">Errore nel caricamento modelli: </system:String>
    <system:String x:Key="NoMicAvailable">Nessun dispositivo di input (mic) disponibile</system:String>
    <system:String x:Key="ErrorLoadingDevices">Errore nel caricamento dispositivi: </system:String>
    <system:String x:Key="None">Nessuno</system:String>
    <system:String x:Key="Default">Predefinito</system:String>
    <system:String x:Key="MicSysStatus">Mic: {0} | Sys: {1}</system:String>
    <system:String x:Key="RecordingInProgress">Registrazione in corso... (mic #{0} + sistema)</system:String>
    <system:String x:Key="StartError">Errore nell'avvio: {0}</system:String>
    <system:String x:Key="RecordingStoppedReadyToSave">Registrazione fermata - Pronto per salvare</system:String>
    <system:String x:Key="FileSaved">File salvato: {0}</system:String>
    <system:String x:Key="StopBeforeSaveError">Fermare la registrazione prima di salvare</system:String>
    <system:String x:Key="NoMicRecordingAvailable">Nessuna registrazione del microfono disponibile</system:String>
    <system:String x:Key="WhisperModelNotFound">Modello Whisper non trovato. Scaricare il file .bin in AppData/AudioRecorder</system:String>
    <system:String x:Key="ChannelsFormat">{0} ({1} canali)</system:String>
    <system:String x:Key="TranscriptionLanguageLabel">Lingua:</system:String>
    <system:String x:Key="EnableTranscriptionLabel">Abilita Trascrizione con Whisper</system:String>
</ResourceDictionary>
