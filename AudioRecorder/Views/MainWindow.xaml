<Window x:Class="AudioRecorder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registratore Audio" 
        Height="350" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" 
                   Text="Registratore Audio - Microfono + Sistema" 
                   FontSize="16" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" 
                    Margin="0,0,0,15">
            <TextBlock Text="Dispositivo di input:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox Name="DeviceComboBox" 
                      Height="25" 
                      SelectionChanged="DeviceComboBox_SelectionChanged"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,15">
            <Button Name="StartButton" 
                    Content="Avvia Registrazione" 
                    Width="150" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="StartButton_Click"
                    Background="#4CAF50" 
                    Foreground="White" 
                    FontWeight="Bold"/>
            
            <Button Name="StopButton" 
                    Content="Ferma Registrazione" 
                    Width="150" 
                    Height="35" 
                    Margin="10,0,0,0"
                    Click="StopButton_Click"
                    IsEnabled="False"
                    Background="#f44336" 
                    Foreground="White" 
                    FontWeight="Bold"/>
        </StackPanel>
        
        <Button Grid.Row="3" 
                Name="SaveButton" 
                Content="Salva Registrazione" 
                Width="200" 
                Height="35" 
                HorizontalAlignment="Center" 
                Click="SaveButton_Click"
                IsEnabled="False"
                Background="#2196F3" 
                Foreground="White" 
                FontWeight="Bold" 
                Margin="0,0,0,20"/>
        
        <Border Grid.Row="4" 
                BorderBrush="#DDD" 
                BorderThickness="1" 
                Padding="10" 
                Background="#F9F9F9">
            <StackPanel>
                <TextBlock Text="Stato:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Name="StatusLabel" 
                          Text="Pronto per registrare" 
                          FontSize="12" 
                          Foreground="#333"/>
            </StackPanel>
        </Border>
        
        <StackPanel Grid.Row="5" 
                    VerticalAlignment="Bottom" 
                    Margin="0,20,0,0">
            <TextBlock Text="Istruzioni:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <TextBlock Text="• Seleziona il dispositivo di input dal menu a tendina" 
                       FontSize="10" 
                       TextWrapping="Wrap" 
                       Margin="0,0,0,2"/>
            <TextBlock Text="• Clicca 'Avvia' per iniziare a registrare microfono e audio di sistema" 
                       FontSize="10" 
                       TextWrapping="Wrap" 
                       Margin="0,0,0,2"/>
            <TextBlock Text="• Clicca 'Ferma' per terminare la registrazione" 
                       FontSize="10" 
                       TextWrapping="Wrap" 
                       Margin="0,0,0,2"/>
            <TextBlock Text="• Clicca 'Salva' per salvare il file WAV mixato" 
                       FontSize="10" 
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
